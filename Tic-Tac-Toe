// Tic-Tac-Toe Game in C++
// Two-player console game on a 3x3 board.

#include <iostream>
#include <limits>

using namespace std;

char board[3][3];

void initBoard() {
    for (int row = 0; row < 3; row++)
        for (int col = 0; col < 3; col++)
            board[row][col] = ' ';
}

void printBoard() {
    cout << "\n";
    for (int row = 0; row < 3; row++) {
        cout << " " << board[row][0] << " | " << board[row][1] << " | " << board[row][2] << " \n";
        if (row < 2)
            cout << "---+---+---\n";
    }
    cout << "\n";
}

bool isBoardFull() {
    for (int row = 0; row < 3; row++)
        for (int col = 0; col < 3; col++)
            if (board[row][col] == ' ')
                return false;
    return true;
}

bool checkWin(char player) {
    // Rows and columns
    for (int i = 0; i < 3; i++) {
        if (board[i][0] == player && board[i][1] == player && board[i][2] == player)
            return true;
        if (board[0][i] == player && board[1][i] == player && board[2][i] == player)
            return true;
    }
    // Diagonals
    if (board[0][0] == player && board[1][1] == player && board[2][2] == player)
        return true;
    if (board[0][2] == player && board[1][1] == player && board[2][0] == player)
        return true;

    return false;
}

void getMove(int &row, int &col, char player) {
    while (true) {
        cout << "Player " << player << ", enter row and column (1-3 1-3): ";
        int r, c;
        cin >> r >> c;

        if (cin.fail()) {
            cin.clear();
            cin.ignore(numeric_limits<streamsize>::max(), '\n');
            cout << "Invalid input. Please enter two numbers between 1 and 3.\n";
            continue;
        }

        row = r - 1;
        col = c - 1;

        if (row < 0 || row > 2 || col < 0 || col > 2) {
            cout << "Out of range. Row and column must be between 1 and 3.\n";
        } else if (board[row][col] != ' ') {
            cout << "That cell is already taken. Try again.\n";
        } else {
            return;
        }
    }
}

int main() {
    cout << "=== Tic-Tac-Toe ===\n";
    cout << "Player 1: X   Player 2: O\n";
    cout << "Enter moves as: row column (each 1-3)\n";

    char again = 'y';
    while (again == 'y' || again == 'Y') {
        initBoard();
        char currentPlayer = 'X';
        bool won = false;

        printBoard();

        while (!isBoardFull() && !won) {
            int row, col;
            getMove(row, col, currentPlayer);
            board[row][col] = currentPlayer;

            printBoard();

            if (checkWin(currentPlayer)) {
                cout << "Player " << currentPlayer << " wins!\n";
                won = true;
            } else {
                currentPlayer = (currentPlayer == 'X') ? 'O' : 'X';
            }
        }

        if (!won) {
            cout << "It's a draw!\n";
        }

        cout << "Play again? (y/n): ";
        cin >> again;
    }

    cout << "Thanks for playing!\n";
    return 0;
